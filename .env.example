# =====================================================================
# Public site
# =====================================================================
NEXT_PUBLIC_SITE_URL=https://main.derbbj6vexl0w.amplifyapp.com
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.org
# Optional: developer/tech-support email shown in the footer for site
# issues. When unset, the support line is hidden.
NEXT_PUBLIC_SUPPORT_EMAIL=

# =====================================================================
# Supabase
# =====================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Server-only. Never expose to the browser. Used by webhook + admin server actions.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Storage bucket names (match supabase/migrations/0003_storage.sql)
SUPABASE_BUCKET_UPLOADS=pet-uploads
SUPABASE_BUCKET_PUBLIC=pet-public

# =====================================================================
# Admin allowlist
# Comma-separated list of Google account emails that should be promoted
# to role='admin' on sign-in (server-side only).
# =====================================================================
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# =====================================================================
# Pledge.to
# Pledge.to is the ONE AND ONLY donation platform for this project.
# Do not add Stripe, Givebutter, Cheddar Up, or PayPal back in.
# =====================================================================

# API key (from your Pledge dashboard). Used to call the Pledge REST API
# from server actions and, if PLEDGE_WEBHOOK_SECRET is not set, as a
# fallback HMAC secret for verifying webhook signatures.
PLEDGE_API_KEY=                                      # TODO

# Webhook signing secret. Prefer setting this explicitly so you can
# rotate it independently of the API key.
PLEDGE_WEBHOOK_SECRET=                               # TODO (recommended)

# REST API base URLs.
PLEDGE_API_BASE_URL=https://api.pledge.to/v1
PLEDGE_SANDBOX_API_BASE_URL=https://api.sandbox.pledge.to/v1

# Default hosted donation URL — campaign or fundraiser page on Pledge.to.
# Used as the fallback "donate to vote" link if a pet has no per-pet URL
# set, and as the entry-donation destination for new submissions.
PLEDGE_DEFAULT_DONATION_URL=https://pledge.to/CAMPAIGN_SLUG  # TODO

# Default widget id / campaign id to use when an admin has not set a
# per-pet override. The webhook also uses these to match incoming
# donations to a pet when no submission_id custom field is present.
PLEDGE_DEFAULT_WIDGET_ID=                            # TODO
PLEDGE_DEFAULT_CAMPAIGN_ID=                          # TODO

# Custom field key the donation form carries through to the webhook
# payload to identify which pet a donation belongs to.
PLEDGE_SUBMISSION_FIELD_KEY=submission_id
