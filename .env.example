# =====================================================================
# Public site
# =====================================================================
NEXT_PUBLIC_SITE_URL=https://liams-pet-project-zacksbrodevs-projects.vercel.app
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.org

# =====================================================================
# Supabase
# =====================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Server-only. Never expose to the browser. Used by webhook + admin server actions.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Storage bucket names (match supabase/migrations/0003_storage.sql)
SUPABASE_BUCKET_UPLOADS=pet-uploads
SUPABASE_BUCKET_PUBLIC=pet-public

# =====================================================================
# Admin allowlist
# Comma-separated list of Google account emails that should be promoted
# to role='admin' on sign-in (server-side only).
# =====================================================================
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# =====================================================================
# Givebutter
# TODOs marked here must be filled in once the Givebutter campaign,
# webhook, and (if available) API key are configured.
# =====================================================================
# Hosted entry-donation checkout (campaign-level URL). The app will append
# a custom field carrying our submission_id so the webhook can match it.
GIVEBUTTER_ENTRY_CHECKOUT_URL=https://givebutter.com/CAMPAIGN_SLUG  # TODO
GIVEBUTTER_CAMPAIGN_ID=                              # TODO
# Custom field key used on the entry checkout to carry our submission_id.
# TODO: confirm the exact key name used in your Givebutter form / webhook payload.
GIVEBUTTER_SUBMISSION_FIELD_KEY=submission_id

# Webhook signing secret (used to verify HMAC on /api/webhooks/givebutter)
GIVEBUTTER_WEBHOOK_SECRET=                           # TODO

# Optional: REST API key for admin "Resync transactions" action
GIVEBUTTER_API_KEY=                                  # TODO (optional)
GIVEBUTTER_API_BASE_URL=https://api.givebutter.com/v1
